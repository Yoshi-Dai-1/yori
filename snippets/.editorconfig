# EditorConfig: エディタ間でコードスタイルを統一する
# https://editorconfig.org
# AIが生成するコードと人間が書くコードのスタイルを一致させる

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{ts,tsx,js,jsx,json,css,scss,html,yaml,yml,md}]
indent_size = 2

[*.py]
indent_size = 4

[*.go]
indent_style = tab
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false
