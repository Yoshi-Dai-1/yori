{
  "_comment": "秘密情報パターンの単一の真実（SSoT）。secrets-guard.ts と pre-commit フックの両方がこのファイルを参照する。パターンを追加・変更する場合はこのファイルのみを編集し、setup-harness.sh を再実行すること。severity: block は編集をブロック（git commit も禁止）、severity: warn は注意喚起のみ（ブロックしない）",
  "filePatterns": [
    "\\.env\\.local$",
    "\\.env\\..+\\.local$",
    "credentials\\.json$",
    "service-account.*\\.json$",
    "\\.pem$",
    "\\.key$",
    "\\.p12$",
    "\\.pfx$",
    "id_rsa$",
    "id_ed25519$",
    "id_dsa$",
    "id_ecdsa$"
  ],
  "contentPatterns": [
    {
      "pattern": "API_KEY\\s*=\\s*.+",
      "label": "API_KEY",
      "severity": "block"
    },
    {
      "pattern": "API_SECRET\\s*=\\s*.+",
      "label": "API_SECRET",
      "severity": "block"
    },
    {
      "pattern": "SECRET_KEY\\s*=\\s*.+",
      "label": "SECRET_KEY",
      "severity": "block"
    },
    {
      "pattern": "PASSWORD\\s*=\\s*.+",
      "label": "PASSWORD",
      "severity": "block"
    },
    {
      "pattern": "PRIVATE_KEY",
      "label": "PRIVATE_KEY",
      "severity": "block"
    },
    {
      "pattern": "ACCESS_TOKEN\\s*=\\s*.+",
      "label": "ACCESS_TOKEN",
      "severity": "block"
    },
    {
      "pattern": "DATABASE_URL\\s*=\\s*.+",
      "label": "DATABASE_URL",
      "severity": "block"
    },
    {
      "pattern": "aws_access_key_id",
      "label": "AWS_ACCESS_KEY_ID",
      "severity": "block"
    },
    {
      "pattern": "aws_secret_access_key",
      "label": "AWS_SECRET_ACCESS_KEY",
      "severity": "block"
    },
    {
      "pattern": "GOOGLE_APPLICATION_CREDENTIALS",
      "label": "GOOGLE_APPLICATION_CREDENTIALS",
      "severity": "block"
    },
    {
      "pattern": "STRIPE_SECRET_KEY",
      "label": "STRIPE_SECRET_KEY",
      "severity": "block"
    },
    {
      "pattern": "SENDGRID_API_KEY",
      "label": "SENDGRID_API_KEY",
      "severity": "block"
    },
    {
      "pattern": "Bearer [A-Za-z0-9+/]",
      "label": "BEARER_TOKEN",
      "severity": "block"
    },
    {
      "pattern": "sk-[a-zA-Z0-9]{20}",
      "label": "OPENAI_KEY",
      "severity": "block"
    },
    {
      "pattern": "ghp_[a-zA-Z0-9]",
      "label": "GITHUB_PAT",
      "severity": "block"
    },
    {
      "pattern": "-----BEGIN.*PRIVATE KEY-----",
      "label": "PRIVATE_KEY_BLOCK",
      "severity": "block"
    },
    {
      "pattern": "\\.innerHTML\\s*=",
      "label": "INNER_HTML",
      "severity": "warn",
      "advice": "Use textContent or framework-safe rendering instead of innerHTML to prevent XSS"
    },
    {
      "pattern": "document\\.write\\s*\\(",
      "label": "DOCUMENT_WRITE",
      "severity": "warn",
      "advice": "Avoid document.write() — use DOM APIs like createElement or framework templates"
    },
    {
      "pattern": "pickle\\.load\\s*\\(",
      "label": "PICKLE_LOAD",
      "severity": "warn",
      "advice": "Pickle can execute arbitrary code during deserialization. Use a safer format like JSON or set weights_only=True"
    }
  ]
}
