## TypeScript 規約

```typescript
// ✅ 良い
const getUserById = async (id: string): Promise<User | null> => { ... };

// ❌ 悪い：any は使わない
const getUser = async (id: any): Promise<any> => { ... };

// ✅ 良い：型引数で明示
const response = await fetch<ApiResponse<User>>('/api/users/1');

// ✅ 良い：unknown で受けてから型ガード
const data: unknown = JSON.parse(raw);
if (isUser(data)) { ... }

// ✅ 良い：const assertion で定数オブジェクトを不変にする
const HTTP_STATUS = {
  OK: 200,
  NOT_FOUND: 404,
} as const;

// ✅ 良い：型エイリアスで意味を与える
type UserId = string;  // string と互換だが意図が明確
type StockCode = string;
```

