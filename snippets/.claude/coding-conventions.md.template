## 関数の書き方

```typescript
// ✅ 良い：単一責任・動詞始まり・型明示
const formatCurrency = (amount: number, currency: 'JPY' | 'USD' = 'JPY'): string => {
  return new Intl.NumberFormat('ja-JP', { style: 'currency', currency }).format(amount);
};

// ✅ 良い：早期リターンで深いネストを避ける
const validateStock = (stock: Stock): ValidationResult => {
  if (!stock.code) return { valid: false, reason: 'コードが未設定' };
  if (!stock.name) return { valid: false, reason: '銘柄名が未設定' };
  return { valid: true };
};

// ❌ 悪い：深いネスト
const validateStock = (stock: Stock): ValidationResult => {
  if (stock.code) {
    if (stock.name) {
      return { valid: true };
    } else {
      return { valid: false, reason: '銘柄名が未設定' };
    }
  } else {
    return { valid: false, reason: 'コードが未設定' };
  }
};
```

