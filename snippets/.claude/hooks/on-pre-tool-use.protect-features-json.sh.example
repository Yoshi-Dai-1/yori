#!/bin/bash
# on-pre-tool-use.protect-features-json.sh.example
# PreToolUseイベント: docs/features.json の passes フィールド不正更新をブロックするHook
#
# 目的:
#   1. 実装エージェントが誤って passes: true を設定するのを防ぐ
#   2. @evaluator のみが passes フィールドを更新できるようにする
#
# セットアップ:
#   1. このファイルを on-pre-tool-use.protect-features-json.sh にコピー
#      cp on-pre-tool-use.protect-features-json.sh.example \
#         on-pre-tool-use.protect-features-json.sh
#   2. chmod +x on-pre-tool-use.protect-features-json.sh
#   3. .claude/settings.json の hooks に登録する
#
# settings.json への登録例:
#   {
#     "hooks": {
#       "PreToolUse": [
#         {
#           "matcher": "Write|Edit",
#           "hooks": [{ "type": "command",
#                       "command": ".claude/hooks/on-pre-tool-use.protect-features-json.sh" }]
#         }
#       ]
#     }
#   }
#
# 終了コード:
#   0 = 正常（Write/Editの実行を許可）
#   2 = ブロック（stderrの内容をエージェントにフィードバックし中止）
#
# Evaluatorによる更新の仕組み:
#   @evaluator は更新前に .claude/.evaluator-updating マーカーファイルを作成する。
#   フックはこのマーカーの存在を検出し、更新を許可する。
#   更新完了後、@evaluator はマーカーファイルを削除する。

FEATURES_JSON="docs/features.json"

# 対象ファイルでない場合はスキップ
# CLAUDE_FILE_PATH が設定されている場合（Claude CodeのPreToolUse）
TARGET_PATH="${CLAUDE_FILE_PATH:-}"
if [ -n "$TARGET_PATH" ]; then
  # フルパスまたは相対パスのどちらでも features.json にマッチするか確認
  BASENAME=$(basename "$TARGET_PATH")
  if [ "$BASENAME" != "features.json" ]; then
    exit 0
  fi
  # docs/ 配下の features.json か確認
  case "$TARGET_PATH" in
    *docs/features.json) ;;
    *)
      # パスに docs/features.json が含まれていない場合はスキップ
      if ! echo "$TARGET_PATH" | grep -q "docs/features.json"; then
        exit 0
      fi
      ;;
  esac
else
  # CLAUDE_FILE_PATH が設定されていない場合は対象外
  exit 0
fi

# jqがインストールされていない場合は簡易モードで動作
USE_JQ=true
if ! command -v jq &> /dev/null; then
  USE_JQ=false
  echo "⚠️ jq が見つかりません。簡易モードで features.json を保護します（精度低下）" >&2
  echo "   正確な保護には jq をインストールしてください: brew install jq（macOS）/ apt install jq（Linux）/ winget install jqlang.jq（Windows）" >&2
fi

# Evaluatorによる正当な更新か確認（マーカーファイルの存在で判定）
if [ -f ".claude/.evaluator-updating" ]; then
  exit 0
fi

# 既存ファイルの passes 値を保存
if [ -f "$FEATURES_JSON" ]; then
  if [ "$USE_JQ" = true ]; then
    OLD_PASSES=$(jq '[.[] | {id: .id, passes: .passes}]' "$FEATURES_JSON" 2>/dev/null)
    if [ $? -ne 0 ]; then
      echo "⚠️ docs/features.json のJSON形式が不正です。更新をブロックしました。" >&2
      exit 2
    fi
  else
    # jqなし: grepで "passes": true/false の行を抽出
    OLD_PASSES=$(grep -o '"passes"[[:space:]]*:[[:space:]]*[a-z]*' "$FEATURES_JSON" 2>/dev/null | sort)
  fi
else
  OLD_PASSES=""
fi

# 新しい内容の passes 値を取得
NEW_CONTENT="${CLAUDE_FILE_CONTENT:-}"
if [ -z "$NEW_CONTENT" ]; then
  exit 0
fi

if [ "$USE_JQ" = true ]; then
  NEW_PASSES=$(echo "$NEW_CONTENT" | jq '[.[] | {id: .id, passes: .passes}]' 2>/dev/null)
  if [ $? -ne 0 ]; then
    echo "🚫 docs/features.json の内容がJSON形式ではありません。更新をブロックしました。" >&2
    exit 2
  fi
else
  NEW_PASSES=$(echo "$NEW_CONTENT" | grep -o '"passes"[[:space:]]*:[[:space:]]*[a-z]*' 2>/dev/null | sort)
fi

# passes の差分を検出
if [ "$USE_JQ" = true ]; then
  DIFF=$(diff <(echo "$OLD_PASSES" | jq -S '.') <(echo "$NEW_PASSES" | jq -S '.') 2>/dev/null)
else
  DIFF=$(diff <(echo "$OLD_PASSES") <(echo "$NEW_PASSES") 2>/dev/null)
fi

if [ -n "$DIFF" ]; then
  echo "" >&2
  echo "🚫 docs/features.json の passes フィールド変更を検出しました。" >&2
  if [ "$USE_JQ" = false ]; then
    echo "   [簡易モード] grepによる簡易比較で検出。正確にはjqで確認してください" >&2
  fi
  echo "" >&2
  echo "passes フィールドは @evaluator のみ更新可能です。" >&2
  echo "変更差分:" >&2
  echo "$DIFF" >&2
  echo "" >&2
  echo "この操作はブロックされました。" >&2
  echo "passes の更新が必要な場合は、@evaluator を呼び出してください。" >&2
  exit 2
fi

# passes に変更がなければ許可（新規フィーチャー追加、sprint変更等）
exit 0
