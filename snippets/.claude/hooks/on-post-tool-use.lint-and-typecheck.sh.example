#!/bin/bash
# on-post-tool-use.lint-and-typecheck.sh.example
# PostToolUseイベント：ファイル書き込み・編集ツール実行後にlint・フォーマット・型チェックを自動実行するHook
#
# 対応言語：TypeScript / JavaScript / Python / Rust / Go / Ruby
#
# セットアップ：
#   1. このファイルを on-post-tool-use.lint-and-typecheck.sh にコピー
#      cp on-post-tool-use.lint-and-typecheck.sh.example \
#         on-post-tool-use.lint-and-typecheck.sh
#   2. chmod +x on-post-tool-use.lint-and-typecheck.sh
#   3. .claude/settings.json の hooks に登録する（.claude/hooks/README.md 参照）
#   4. 下記「設定」セクションをプロジェクトに合わせて変更する
#
# 終了コード：
#   0 = 正常終了（Claude Codeは続行）
#   2 = エラー（stderrの内容をClaude Codeがエージェントにフィードバック）

# ===== 設定（プロジェクトに合わせて変更する） =====

# TypeScript / JavaScript
ENABLE_TYPECHECK=true           # TypeScriptプロジェクトの場合 true
ENABLE_JS_LINT=true             # ESLint を使う場合 true
ENABLE_JS_FORMAT=true           # Prettier を使う場合 true
TYPECHECK_CMD="pnpm typecheck"  # AGENTS.md の Type check コマンドに合わせる
JS_LINT_CMD="pnpm lint"         # AGENTS.md の Lint コマンドに合わせる
JS_FORMAT_CMD="pnpm prettier --write"  # フォーマットコマンド

# Python
ENABLE_PY_LINT=true             # Ruff lint を使う場合 true
ENABLE_PY_FORMAT=true           # Ruff format を使う場合 true（Black を使う場合は false にして ENABLE_PY_BLACK=true）
ENABLE_PY_BLACK=false           # Black を使う場合 true（Ruff を使う場合は false）

# Rust
ENABLE_RUST_LINT=true           # Clippy を使う場合 true
ENABLE_RUST_FORMAT=true         # rustfmt を使う場合 true

# Go
ENABLE_GO_LINT=true             # staticcheck / go vet を使う場合 true
ENABLE_GO_FORMAT=true           # gofmt を使う場合 true

# Ruby
ENABLE_RUBY_LINT=true           # RuboCop lint を使う場合 true
ENABLE_RUBY_FORMAT=true         # RuboCop auto-correct を使う場合 true

# ===== ここから下は変更不要 =====

INPUT=$(cat)

if command -v python3 &>/dev/null; then
  FILE_PATH=$(echo "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
    inp = d.get('tool_input', {})
    print(inp.get('file_path') or inp.get('path') or '')
except Exception:
    print('')
" 2>/dev/null)
fi

if [ -z "$FILE_PATH" ] || [ ! -f "$FILE_PATH" ]; then
  exit 0
fi

ERRORS=""

# ─── TypeScript / JavaScript ──────────────────────────────────────────────────
if [[ "$FILE_PATH" =~ \.(ts|tsx|js|jsx|mts|cts|mjs|cjs)$ ]]; then

  # フォーマット（Prettier）
  if [ "$ENABLE_JS_FORMAT" = true ] && command -v pnpm &>/dev/null; then
    FMT_OUT=$($JS_FORMAT_CMD "$FILE_PATH" 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[Prettierフォーマットエラー]\n${FMT_OUT}\n\n"
    fi
  fi

  # 型チェック（tsc）
  if [ "$ENABLE_TYPECHECK" = true ] && command -v pnpm &>/dev/null; then
    TSC_OUT=$($TYPECHECK_CMD 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[型チェックエラー]\n${TSC_OUT}\n\n"
    fi
  fi

  # Lint（ESLint）
  if [ "$ENABLE_JS_LINT" = true ] && command -v pnpm &>/dev/null; then
    LINT_OUT=$($JS_LINT_CMD "$FILE_PATH" 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[ESLint エラー]\n${LINT_OUT}\n\n"
    fi
  fi
fi

# ─── Python ───────────────────────────────────────────────────────────────────
if [[ "$FILE_PATH" =~ \.py$ ]]; then

  # フォーマット（Ruff format または Black）
  if [ "$ENABLE_PY_FORMAT" = true ] && command -v ruff &>/dev/null; then
    ruff format "$FILE_PATH" 2>/dev/null
  elif [ "$ENABLE_PY_BLACK" = true ] && command -v black &>/dev/null; then
    black "$FILE_PATH" 2>/dev/null
  fi

  # Lint（Ruff）
  if [ "$ENABLE_PY_LINT" = true ] && command -v ruff &>/dev/null; then
    RUFF_OUT=$(ruff check "$FILE_PATH" 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[Ruff lint エラー]\n${RUFF_OUT}\n\n"
    fi
  fi
fi

# ─── Rust ──────────────────────────────────────────────────────────────────────
if [[ "$FILE_PATH" =~ \.rs$ ]]; then

  # フォーマット（rustfmt）
  if [ "$ENABLE_RUST_FORMAT" = true ] && command -v rustfmt &>/dev/null; then
    rustfmt "$FILE_PATH" 2>/dev/null
  fi

  # Lint（Clippy）※ cargo clippy はファイル単体ではなくプロジェクト全体に実行する
  if [ "$ENABLE_RUST_LINT" = true ] && command -v cargo &>/dev/null; then
    CLIPPY_OUT=$(cargo clippy --quiet 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[Clippy エラー]\n${CLIPPY_OUT}\n\n"
    fi
  fi
fi

# ─── Go ────────────────────────────────────────────────────────────────────────
if [[ "$FILE_PATH" =~ \.go$ ]]; then

  # フォーマット（gofmt）
  if [ "$ENABLE_GO_FORMAT" = true ] && command -v gofmt &>/dev/null; then
    gofmt -w "$FILE_PATH" 2>/dev/null
  fi

  # Lint（go vet）
  if [ "$ENABLE_GO_LINT" = true ] && command -v go &>/dev/null; then
    PKG_DIR=$(dirname "$FILE_PATH")
    VET_OUT=$(go vet "./$PKG_DIR/..." 2>&1)
    if [ $? -ne 0 ]; then
      ERRORS="${ERRORS}[go vet エラー]\n${VET_OUT}\n\n"
    fi
  fi
fi

# ─── Ruby ──────────────────────────────────────────────────────────────────────
if [[ "$FILE_PATH" =~ \.rb$ ]]; then

  # フォーマット + Lint（RuboCop。-A で自動修正可能なものを修正し、残りをエラー報告）
  if ([ "$ENABLE_RUBY_FORMAT" = true ] || [ "$ENABLE_RUBY_LINT" = true ]) && command -v rubocop &>/dev/null; then
    if [ "$ENABLE_RUBY_FORMAT" = true ]; then
      rubocop --autocorrect-all --no-color "$FILE_PATH" 2>/dev/null
    fi
    if [ "$ENABLE_RUBY_LINT" = true ]; then
      RUBOCOP_OUT=$(rubocop --no-color "$FILE_PATH" 2>&1)
      if [ $? -ne 0 ]; then
        ERRORS="${ERRORS}[RuboCop エラー]\n${RUBOCOP_OUT}\n\n"
      fi
    fi
  fi
fi

if [ -n "$ERRORS" ]; then
  echo -e "$ERRORS" >&2
  exit 2
fi

exit 0
