#!/bin/bash
# on-stop.generate-handoff.sh.example
# Stopイベント：セッション終了時にhandoff-artifact.mdを生成するHook
# コンテキストリセット時に次のセッションへ状態を引き継ぐための仕組み
#
# セットアップ：
#   1. このファイルを on-stop.generate-handoff.sh にコピー
#   2. 実行権限を付与: chmod +x .claude/hooks/on-stop.generate-handoff.sh
#   3. Claude Codeの設定でStopイベントに登録

DATETIME=$(date +%Y-%m-%d\ %H:%M)
HANDOFF_FILE=".claude/handoff-artifact.md"

# handoff-artifact.md を生成する
# Note: このHookはテンプレートを生成する。
#       AIがセッション中に handoff スキルを使った場合は内容が記入済みになる。
#       handoff スキルを使わなかった場合はこのテンプレートが残るため、
#       次のセッションで handoff スキルを呼び出して内容を記入する。
# handoff SKILL が記入済みかどうかを「HANDOFF_FILLED」マーカーで判定する
# handoff SKILL は記入完了時に HANDOFF_FILLED を埋め込む（handoff/SKILL.md 参照）
if [ ! -f "$HANDOFF_FILE" ] || ! grep -q "HANDOFF_FILLED" "$HANDOFF_FILE" 2>/dev/null; then
  cat > "$HANDOFF_FILE" << EOF
# Handoff Artifact
# 更新日時: $DATETIME
# このファイルは次のセッション開始時にコンテキストとして渡す
# 内容が空欄の場合は次のセッション開始時に handoff スキルを使って内容を記入する

## 前のセッションの状態

取り組んでいた機能:
完了した部分:
途中で止まっている部分:
次にやるべきこと:

## 重要な決定事項


## 未解決の問題


## 変更したファイル

$(git diff --name-only 2>/dev/null || echo "git管理外")

EOF
  echo "📝 Handoff Artifact テンプレートを生成しました: $HANDOFF_FILE"
else
  echo "📝 Handoff Artifact は既に記入済みです: $HANDOFF_FILE"
fi

# build-log.md にセッション終了の行を追記する（Hook が確実に記録する）
# handoff スキルが使われた場合、このスクリプトとは別に最終行を実際の内容で更新する
BUILD_LOG="docs/build-log.md"
DATE=$(date +%Y-%m-%d)
mkdir -p docs
if [ ! -f "$BUILD_LOG" ]; then
  printf "# Build Log\n\n| 日付 | 内容 | 未解決 |\n|------|------|--------|\n" > "$BUILD_LOG"
fi
printf "| %s | （更新待ち） | - |\n" "$DATE" >> "$BUILD_LOG"
echo "📋 Build Log に行を追記しました: $BUILD_LOG"

echo ""
echo "   ✅ $HANDOFF_FILE を更新しました"
echo "   次のセッション開始時に AGENTS.md の Session Protocol が自動で読み込みます"
echo "   handoff スキルを使った場合は build-log.md の最終行が実際の内容に更新されます"
