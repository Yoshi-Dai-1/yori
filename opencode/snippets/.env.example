# =============================================================================
# 環境変数テンプレート
# このファイルは .gitignore されません（チームで共有する）
# 実際の値は .env に記入し、絶対にコミットしない
# =============================================================================
#
# 【ルール】
# - 新しい環境変数を追加したら、必ずこのファイルにもキー名を追加する
# - 値は空にするか、例示値（本物でないもの）のみ記入する
# - 機密性の説明コメントを必ず書く
#
# =============================================================================

# --- アプリケーション設定 ---
# NODE_ENV=development
# PORT=3000
# APP_URL=http://localhost:3000

# --- データベース ---
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# REDIS_URL=redis://localhost:6379

# --- 認証 ---
# JWT_SECRET=
# SESSION_SECRET=

# --- 外部サービス（キーはダッシュボードから取得）---
# OPENAI_API_KEY=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# SENDGRID_API_KEY=

# --- クラウド（本番環境のみ）---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-northeast-1
# GCP_PROJECT_ID=
